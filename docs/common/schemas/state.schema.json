{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeOS Session State",
  "description": "Schema for state.json — session runtime state management (v7.4)",
  "type": "object",
  "required": ["execution", "token", "stable", "session", "goal", "kpi", "automation"],
  "properties": {
    "project": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mode": { "type": "string", "enum": ["autonomous", "manual", "hybrid"] }
      }
    },
    "execution": {
      "type": "object",
      "required": ["start_time", "max_duration_minutes", "elapsed_minutes", "remaining_minutes", "phase"],
      "properties": {
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "type": "string", "format": "date-time" },
        "max_duration_minutes": { "type": "integer", "minimum": 1 },
        "elapsed_minutes": { "type": "integer", "minimum": 0 },
        "remaining_minutes": { "type": "integer", "minimum": 0 },
        "phase": { "type": "string", "enum": ["Monitor", "Development", "Verify", "Improvement", "Debug", "Release", "STABLE"] },
        "loop_number": { "type": "integer", "minimum": 1 },
        "auto_stop_threshold": { "type": "integer", "minimum": 1 },
        "graceful_shutdown": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["light", "full"], "description": "role-contracts.md §1 の運用モード (既定 light)" },
        "retry_count_by_cause": { "type": "object", "description": "Loop Guard: 原因別リトライ回数" },
        "no_progress_streak": { "type": "integer", "minimum": 0, "description": "Loop Guard: 連続進展なし回数 (閾値 2 で停止)" },
        "same_diff_streak": { "type": "integer", "minimum": 0, "description": "Loop Guard: 同一差分再生成回数 (閾値 2 で停止)" },
        "last_stop_reason": { "type": "string", "description": "Loop Guard: 直近の停止理由 (handoff レポート生成に使用)" },
        "pending": { "type": "array", "items": { "type": "object" }, "description": "Build Loop が記録する未完了項目。Loop Guard が handoff レポート合成時に読む" },
        "pending_verify": { "type": "array", "items": { "type": "object" }, "description": "Verify Loop が記録する未判定項目。Loop Guard が handoff レポート合成時に読む" }
      }
    },
    "token": {
      "type": "object",
      "required": ["total_budget", "used", "remaining"],
      "properties": {
        "total_budget": { "type": "integer", "minimum": 1 },
        "used": { "type": "integer", "minimum": 0 },
        "remaining": { "type": "integer", "minimum": 0 },
        "allocation": { "type": "object" },
        "dynamic_mode": { "type": "boolean" },
        "current_phase_budget": { "type": "integer", "minimum": 0 },
        "current_phase_used": { "type": "integer", "minimum": 0 }
      }
    },
    "stable": {
      "type": "object",
      "required": ["consecutive_success", "target_n"],
      "properties": {
        "consecutive_success": { "type": "integer", "minimum": 0 },
        "target_n": { "type": "integer", "minimum": 1 },
        "last_check": { "type": "string" },
        "test_passed": { "type": "integer", "minimum": 0 },
        "test_failed": { "type": "integer", "minimum": 0 },
        "ci_status": { "type": "string" }
      }
    },
    "session": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "type": "string" },
        "issues_in_progress": { "type": "array", "items": { "type": "integer" } },
        "blocked_issues": { "type": "array", "items": { "type": "integer" } },
        "completed_this_session": { "type": "array", "items": { "type": "integer" } },
        "pr_open": { "type": "array", "items": { "type": "integer" } },
        "pr_merged": { "type": "array", "items": { "type": "integer" } },
        "pr_closed": { "type": "array", "items": { "type": "integer" } }
      }
    },
    "goal": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "phase": { "type": "integer" },
        "target_version": { "type": "string" }
      }
    },
    "kpi": {
      "type": "object",
      "required": ["success_rate_target"],
      "properties": {
        "success_rate_target": { "type": "number", "minimum": 0, "maximum": 1 },
        "test_pass_rate_target": { "type": "number", "minimum": 0, "maximum": 1 },
        "review_blocker_target": { "type": "integer", "minimum": 0 },
        "security_blocker_target": { "type": "integer", "minimum": 0 },
        "ci_stability_target": { "type": "number", "minimum": 0, "maximum": 1 },
        "test_count_target": { "type": "integer", "minimum": 0 },
        "test_count_actual": { "type": "integer", "minimum": 0 }
      }
    },
    "priority": {
      "type": "object",
      "properties": {
        "weights": { "type": "object" },
        "current_top_reason": { "type": "string" }
      }
    },
    "codex": {
      "type": "object",
      "properties": {
        "setup_checked": { "type": "boolean" },
        "review_gate": { "type": "string" },
        "last_review_status": { "type": "string" },
        "last_review_type": { "type": "string" },
        "last_review_job_id": { "type": "string" },
        "last_review_summary": { "type": "string" },
        "blocking_issues": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string" }
      }
    },
    "debug": {
      "type": "object",
      "properties": {
        "last_failure_category": { "type": "string" },
        "failure_count_by_category": { "type": "object" },
        "same_error_retry_count": { "type": "integer", "minimum": 0 },
        "rescue_retry_count": { "type": "integer", "minimum": 0 },
        "last_root_cause": { "type": "string" },
        "last_fix_scope": { "type": "string" },
        "last_fix_strategy": { "type": "string" },
        "flaky_suspected": { "type": "boolean" },
        "debug_mode": { "type": "string" }
      }
    },
    "automation": {
      "type": "object",
      "properties": {
        "auto_issue_generation": { "type": "boolean" },
        "auto_project_sync": { "type": "boolean" },
        "self_evolution": { "type": "boolean" },
        "auto_priority_scoring": { "type": "boolean" },
        "auto_repair": { "type": "boolean" },
        "architecture_check": { "type": "boolean" }
      }
    },
    "learning": {
      "type": "object",
      "properties": {
        "failure_patterns": { "type": "array", "items": { "type": "string" } },
        "success_patterns": { "type": "array", "items": { "type": "string" } },
        "blocked_patterns": { "type": "array", "items": { "type": "string" } },
        "preferred_fix_order": { "type": "array", "items": { "type": "string" } }
      }
    },
    "github": {
      "type": "object",
      "properties": {
        "default_branch": { "type": "string" },
        "require_pr": { "type": "boolean" },
        "require_codex_review": { "type": "boolean" },
        "require_actions_success": { "type": "boolean" },
        "project_sync_enabled": { "type": "boolean" }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "stable": { "type": "boolean" },
        "blocked": { "type": "boolean" },
        "current_phase": { "type": "string" },
        "last_updated": { "type": "string" }
      }
    }
  }
}
